{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM"],
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@/*": ["assets/scripts/*"]
    }
  },
  "include": ["assets/scripts/**/*.ts", "types/**/*.d.ts"]
}
